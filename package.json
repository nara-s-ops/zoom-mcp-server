{
  "name": "zoom-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP Server for Zoom API",
  "main": "src/index.js",
  "scripts": {
    "start": "supergateway --stdio 'node src/index.js' --port ${PORT:-3000} --baseUrl ${BASE_URL:-http://localhost:3000} --ssePath /mcp --messagePath /mcp/message"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "supergateway": "latest"
  }
}
